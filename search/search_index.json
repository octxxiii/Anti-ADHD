{"config":{"lang":["ko"],"separator":"[\\s\\-\\.]+","pipeline":[" "]},"docs":[{"location":"","title":"Anti-ADHD","text":"<p>\uc544\uc774\uc820\ud558\uc6cc \ub9e4\ud2b8\ub9ad\uc2a4\ub85c ADHD\ub97c \uc774\uae30\ub294 \ud560 \uc77c \uad00\ub9ac \ud504\ub85c\uadf8\ub7a8</p> <ul> <li> <p> \ube60\ub978 \uc2dc\uc791</p> <p> \ub2e4\uc6b4\ub85c\ub4dc  \uc0ac\uc6a9\ubc95</p> </li> <li> <p> \uc8fc\uc694 \uae30\ub2a5</p> <ul> <li>\ud83c\udfaf \uc544\uc774\uc820\ud558\uc6cc \ub9e4\ud2b8\ub9ad\uc2a4</li> <li>\ud83d\udccc \ud56d\uc0c1 \uc704</li> <li>\ud83d\udd0d \ud22c\uba85\ub3c4 \uc870\uc808</li> <li>\ud83d\udcbe \uc790\ub3d9 \uc800\uc7a5</li> <li>\ud83d\udd04 \uc790\ub3d9 \uc5c5\ub370\uc774\ud2b8</li> </ul> </li> <li> <p> \ub3c4\uc6c0\ub9d0</p> <p> FAQ  \ubb38\uc81c \ud574\uacb0</p> </li> </ul>"},{"location":"#_1","title":"\ud83d\ude80 \uc2dc\uc791\ud558\uae30","text":"<ol> <li>\ub9b4\ub9ac\uc988 \ud398\uc774\uc9c0\uc5d0\uc11c \ucd5c\uc2e0 \ubc84\uc804\uc758 <code>anti_adhd.exe</code> \ub2e4\uc6b4\ub85c\ub4dc</li> <li>\ub2e4\uc6b4\ub85c\ub4dc\ud55c \ud30c\uc77c \uc2e4\ud589</li> <li>\ud504\ub85c\uadf8\ub7a8\uc744 \uc2e4\ud589\ud558\uace0 \ud560 \uc77c\uc744 \uad00\ub9ac\ud558\uc138\uc694!</li> </ol> <p>\uc9c0\uc6d0 \ud658\uacbd</p> <p>\ud604\uc7ac Windows \uc6b4\uc601\uccb4\uc81c\ub9cc \uc9c0\uc6d0\ud569\ub2c8\ub2e4.</p>"},{"location":"#_2","title":"\ud83c\udfa8 \uc0ac\uc6a9\ubc95","text":"\ud560 \uc77c \ucd94\uac00\ud560 \uc77c \uad00\ub9ac\uc124\uc815 <ul> <li>\uac01 \ubd84\uba74\uc758 \uc785\ub825\ucc3d\uc5d0 \ud560 \uc77c\uc744 \uc785\ub825\ud558\uace0 Enter \ud0a4\ub97c \ub204\ub974\uac70\ub098 \ucd94\uac00 \ubc84\ud2bc\uc744 \ud074\ub9ad</li> <li>\uc911\uc694\ub3c4\uc640 \uae34\uae09\ub3c4\uc5d0 \ub530\ub77c \uc801\uc808\ud55c \ubd84\uba74\uc744 \uc120\ud0dd</li> </ul> <ul> <li>\uccb4\ud06c\ubc15\uc2a4\ub85c \uc644\ub8cc\ub41c \ud560 \uc77c\uc744 \ud45c\uc2dc</li> <li>\ub354\ube14 \ud074\ub9ad\uc73c\ub85c \ud560 \uc77c\uc758 \ub0b4\uc6a9\uc744 \uc218\uc815</li> <li>\uc6b0\ud074\ub9ad \uba54\ub274\ub85c \uc0c1\uc138\ubcf4\uae30, \uc218\uc815, \uc0ad\uc81c \uac00\ub2a5</li> </ul> <ul> <li>\u2699\ufe0f \ubc84\ud2bc\uc744 \ud074\ub9ad\ud558\uc5ec \uc124\uc815 \ucc3d \uc5f4\uae30</li> <li>\ud22c\uba85\ub3c4, \ud56d\uc0c1 \uc704 \ub4f1 \uc124\uc815 \uac00\ub2a5</li> </ul>"},{"location":"#_3","title":"\ud83d\udc68\u200d\ud83d\udcbb \uac1c\ubc1c\uc790 \ubc0f \ub77c\uc774\uc120\uc2a4","text":"<ul> <li> GitHub</li> <li> \uc774\uba54\uc77c</li> <li> MIT License</li> </ul>"},{"location":"#_4","title":"\ud83e\udd1d \uae30\uc5ec\ud558\uae30","text":"<p>\ud504\ub85c\uc81d\ud2b8\uc5d0 \uae30\uc5ec\ud558\uace0 \uc2f6\uc73c\uc2e0\uac00\uc694? \uc5b8\uc81c\ub4e0 \ud658\uc601\ud569\ub2c8\ub2e4!</p> <ol> <li>\uc774 \uc800\uc7a5\uc18c\ub97c \ud3ec\ud06c</li> <li>\uc0c8\ub85c\uc6b4 \ube0c\ub79c\uce58 \uc0dd\uc131</li> <li>\ubcc0\uacbd\uc0ac\ud56d\uc744 \ucee4\ubc0b</li> <li>\ube0c\ub79c\uce58\ub97c \ud478\uc2dc</li> <li>Pull Request \uc0dd\uc131</li> </ol>"},{"location":"#v101","title":"\ucd5c\uadfc \ubcc0\uacbd\uc0ac\ud56d (v1.0.1)","text":"UI \uac1c\uc120\uae30\ub2a5 \uac1c\uc120 <ul> <li>\uc124\uc815 \ucc3d \ud06c\uae30 \ubc0f \uc704\uce58 \ucd5c\uc801\ud654</li> <li>\uc5ec\ubc31 \uc870\uc815\uc73c\ub85c \ub354 \ucef4\ud329\ud2b8\ud55c \ub808\uc774\uc544\uc6c3</li> <li>\uc815\ubcf4 \ud0ed \uc2a4\ud06c\ub864 \uae30\ub2a5 \ucd94\uac00</li> <li>\uc774\uba54\uc77c\uacfc GitHub \ub9c1\ud06c \ud074\ub9ad \uac00\ub2a5\ud558\ub3c4\ub85d \uac1c\uc120</li> </ul> <ul> <li>\uc790\ub3d9 \uc5c5\ub370\uc774\ud2b8 \uae30\ub2a5 \ucd94\uac00</li> <li>GitHub \ub9b4\ub9ac\uc988 \uae30\ubc18 \ubc84\uc804 \uccb4\ud06c</li> <li>\uc790\ub3d9 \ub2e4\uc6b4\ub85c\ub4dc \ubc0f \uc124\uce58 \uc9c0\uc6d0</li> <li>\ub370\uc774\ud130 \uad00\ub9ac \uac1c\uc120</li> <li>\ud504\ub85c\uadf8\ub7a8 \uc2dc\uc791 \uc2dc \uc790\ub3d9 \ubd88\ub7ec\uc624\uae30 \uc54c\ub9bc \uc81c\uac70</li> <li>\uc124\uc815 \ucc3d\uc5d0\uc11c \uc218\ub3d9 \ubd88\ub7ec\uc624\uae30 \uc2dc\uc5d0\ub9cc \uc54c\ub9bc \ud45c\uc2dc </li> </ul>"},{"location":"faq/","title":"\uc790\uc8fc \ubb3b\ub294 \uc9c8\ubb38","text":"<ul> <li> <p> \uc77c\ubc18\uc801\uc778 \uc9c8\ubb38</p> <ul> <li>\ud504\ub85c\uadf8\ub7a8 \uc2dc\uc791 \ubc29\ubc95</li> <li>\ub370\uc774\ud130 \uc800\uc7a5 \uc704\uce58</li> <li>\ucc3d \uace0\uc815 \ubc29\ubc95</li> </ul> </li> <li> <p> \uae30\ub2a5 \uad00\ub828 \uc9c8\ubb38</p> <ul> <li>\ud560 \uc77c \uc218\uc815 \ubc29\ubc95</li> <li>\uccb4\ud06c\ub9ac\uc2a4\ud2b8 \uc778\uc1c4</li> <li>\uc790\ub3d9 \uc800\uc7a5 \uae30\ub2a5</li> </ul> </li> <li> <p> \ubb38\uc81c \ud574\uacb0</p> <ul> <li>\ud504\ub85c\uadf8\ub7a8 \uc2e4\ud589 \ubb38\uc81c</li> <li>\ub370\uc774\ud130 \ubcf5\uad6c</li> <li>\uc5c5\ub370\uc774\ud2b8 \uc54c\ub9bc</li> </ul> </li> </ul>"},{"location":"faq/#_2","title":"\uc77c\ubc18\uc801\uc778 \uc9c8\ubb38","text":"\ud504\ub85c\uadf8\ub7a8\uc744 \uc5b4\ub5bb\uac8c \uc2dc\uc791\ud558\ub098\uc694?\ub370\uc774\ud130\ub294 \uc5b4\ub514\uc5d0 \uc800\uc7a5\ub418\ub098\uc694?\ucc3d\uc744 \ud56d\uc0c1 \uc704\uc5d0 \uace0\uc815\ud558\ub824\uba74 \uc5b4\ub5bb\uac8c \ud558\ub098\uc694? <p><code>anti_adhd.py</code> \ud30c\uc77c\uc744 \uc2e4\ud589\ud558\uba74 \ud504\ub85c\uadf8\ub7a8\uc774 \uc2dc\uc791\ub429\ub2c8\ub2e4. Python\uc774 \uc124\uce58\ub418\uc5b4 \uc788\uc5b4\uc57c \ud569\ub2c8\ub2e4.</p> <p>\ub370\uc774\ud130\ub294 \ud504\ub85c\uadf8\ub7a8\uc774 \uc2e4\ud589\ub41c \ub514\ub809\ud1a0\ub9ac\uc758 <code>checklist_data.json</code> \ud30c\uc77c\uc5d0 \uc800\uc7a5\ub429\ub2c8\ub2e4.</p> <p>\uc124\uc815 \ucc3d\uc758 \ud83d\udccc \ubc84\ud2bc\uc744 \ud074\ub9ad\ud558\uba74 \ucc3d\uc774 \ud56d\uc0c1 \uc704\uc5d0 \uace0\uc815\ub429\ub2c8\ub2e4.</p>"},{"location":"faq/#_3","title":"\uae30\ub2a5 \uad00\ub828 \uc9c8\ubb38","text":"\ud560 \uc77c\uc744 \uc218\uc815\ud558\ub824\uba74 \uc5b4\ub5bb\uac8c \ud558\ub098\uc694?\uccb4\ud06c\ub9ac\uc2a4\ud2b8\ub97c \uc778\uc1c4\ud560 \uc218 \uc788\ub098\uc694?\uc790\ub3d9 \uc800\uc7a5\uc740 \uc5b4\ub5bb\uac8c \uc791\ub3d9\ud558\ub098\uc694? <p>\ud56d\ubaa9\uc744 \ub354\ube14 \ud074\ub9ad\ud558\uac70\ub098 \uc6b0\ud074\ub9ad \ud6c4 '\uc218\uc815' \uba54\ub274\ub97c \uc120\ud0dd\ud558\uc5ec \uc218\uc815\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</p> <p>\ub124, \uc124\uc815 \ucc3d\uc758 \uc778\uc1c4 \ubc84\ud2bc\uc744 \ud074\ub9ad\ud558\uc5ec \uccb4\ud06c\ub9ac\uc2a4\ud2b8\ub97c \uc778\uc1c4\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</p> <p>\ud504\ub85c\uadf8\ub7a8\uc740 \ud56d\ubaa9\uc774 \ucd94\uac00, \uc218\uc815, \uc0ad\uc81c\ub420 \ub54c\ub9c8\ub2e4 \uc790\ub3d9\uc73c\ub85c \ub370\uc774\ud130\ub97c \uc800\uc7a5\ud569\ub2c8\ub2e4.</p>"},{"location":"faq/#_4","title":"\ubb38\uc81c \ud574\uacb0","text":"\ud504\ub85c\uadf8\ub7a8\uc774 \uc2e4\ud589\ub418\uc9c0 \uc54a\uc544\uc694\ub370\uc774\ud130\uac00 \uc0ac\ub77c\uc84c\uc5b4\uc694\uc5c5\ub370\uc774\ud2b8 \uc54c\ub9bc\uc774 \uacc4\uc18d \ud45c\uc2dc\ub3fc\uc694 <p>Python\uc774 \uc124\uce58\ub418\uc5b4 \uc788\ub294\uc9c0 \ud655\uc778\ud558\uace0, \ud544\uc694\ud55c \ub77c\uc774\ube0c\ub7ec\ub9ac(tkinter)\uac00 \uc124\uce58\ub418\uc5b4 \uc788\ub294\uc9c0 \ud655\uc778\ud558\uc138\uc694.</p> <p><code>checklist_data.json</code> \ud30c\uc77c\uc774 \uc788\ub294\uc9c0 \ud655\uc778\ud558\uace0, \ubc31\uc5c5 \ud30c\uc77c(<code>checklist_data.json.bak</code>)\uc774 \uc788\ub2e4\uba74 \ubcf5\uc6d0\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</p> <p>\ucd5c\uc2e0 \ubc84\uc804\uc73c\ub85c \uc5c5\ub370\uc774\ud2b8\ud558\uac70\ub098, \uc124\uc815\uc5d0\uc11c \uc790\ub3d9 \uc5c5\ub370\uc774\ud2b8 \ud655\uc778\uc744 \ube44\ud65c\uc131\ud654\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. </p>"},{"location":"troubleshooting/","title":"\ubb38\uc81c \ud574\uacb0 \uac00\uc774\ub4dc","text":"<ul> <li> <p> \uc77c\ubc18\uc801\uc778 \ubb38\uc81c</p> <ul> <li>\ud504\ub85c\uadf8\ub7a8 \uc2e4\ud589 \ubb38\uc81c</li> <li>\ub370\uc774\ud130 \uc800\uc7a5 \ubb38\uc81c</li> <li>\ub370\uc774\ud130 \ubcf5\uad6c</li> </ul> </li> <li> <p> \uae30\ub2a5 \uad00\ub828 \ubb38\uc81c</p> <ul> <li>\ucc3d \uace0\uc815 \ubb38\uc81c</li> <li>\ud22c\uba85\ub3c4 \uc870\uc808 \ubb38\uc81c</li> <li>\uc778\uc1c4 \ubb38\uc81c</li> </ul> </li> <li> <p> \uc5c5\ub370\uc774\ud2b8 \uad00\ub828 \ubb38\uc81c</p> <ul> <li>\uc5c5\ub370\uc774\ud2b8 \uc54c\ub9bc</li> <li>\uc5c5\ub370\uc774\ud2b8 \ud6c4 \ubb38\uc81c</li> </ul> </li> </ul>"},{"location":"troubleshooting/#_2","title":"\uc77c\ubc18\uc801\uc778 \ubb38\uc81c","text":"\ud504\ub85c\uadf8\ub7a8\uc774 \uc2e4\ud589\ub418\uc9c0 \uc54a\ub294 \uacbd\uc6b0\ub370\uc774\ud130\uac00 \uc800\uc7a5\ub418\uc9c0 \uc54a\ub294 \uacbd\uc6b0\ub370\uc774\ud130\uac00 \uc0ac\ub77c\uc9c4 \uacbd\uc6b0 <ol> <li>Python\uc774 \uc124\uce58\ub418\uc5b4 \uc788\ub294\uc9c0 \ud655\uc778\ud558\uc138\uc694.</li> <li>\ud544\uc694\ud55c \ub77c\uc774\ube0c\ub7ec\ub9ac(tkinter)\uac00 \uc124\uce58\ub418\uc5b4 \uc788\ub294\uc9c0 \ud655\uc778\ud558\uc138\uc694.</li> <li>\uad00\ub9ac\uc790 \uad8c\ud55c\uc73c\ub85c \uc2e4\ud589\ud574\ubcf4\uc138\uc694.</li> </ol> <ol> <li>\ud504\ub85c\uadf8\ub7a8\uc774 \uc788\ub294 \ud3f4\ub354\uc5d0 \uc4f0\uae30 \uad8c\ud55c\uc774 \uc788\ub294\uc9c0 \ud655\uc778\ud558\uc138\uc694.</li> <li><code>checklist_data.json</code> \ud30c\uc77c\uc774 \uc77d\uae30 \uc804\uc6a9\uc740 \uc544\ub2cc\uc9c0 \ud655\uc778\ud558\uc138\uc694.</li> <li>\ud504\ub85c\uadf8\ub7a8\uc744 \uad00\ub9ac\uc790 \uad8c\ud55c\uc73c\ub85c \uc2e4\ud589\ud574\ubcf4\uc138\uc694.</li> </ol> <ol> <li><code>checklist_data.json</code> \ud30c\uc77c\uc774 \uc788\ub294\uc9c0 \ud655\uc778\ud558\uc138\uc694.</li> <li>\ubc31\uc5c5 \ud30c\uc77c(<code>checklist_data.json.bak</code>)\uc774 \uc788\ub2e4\uba74 \ubcf5\uc6d0\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> <li>\ubc31\uc5c5 \ud30c\uc77c\uc774 \uc5c6\ub2e4\uba74, \uc774\uc804 \ubc84\uc804\uc758 \ud30c\uc77c\uc744 \ubcf5\uc6d0\ud574\ubcf4\uc138\uc694.</li> </ol>"},{"location":"troubleshooting/#_3","title":"\uae30\ub2a5 \uad00\ub828 \ubb38\uc81c","text":"\ucc3d\uc774 \ud56d\uc0c1 \uc704\uc5d0 \uace0\uc815\ub418\uc9c0 \uc54a\ub294 \uacbd\uc6b0\ud22c\uba85\ub3c4\uac00 \uc870\uc808\ub418\uc9c0 \uc54a\ub294 \uacbd\uc6b0\uc778\uc1c4\uac00 \ub418\uc9c0 \uc54a\ub294 \uacbd\uc6b0 <ol> <li>\uc124\uc815 \ucc3d\uc758 \ud83d\udccc \ubc84\ud2bc\uc774 \ud65c\uc131\ud654\ub418\uc5b4 \uc788\ub294\uc9c0 \ud655\uc778\ud558\uc138\uc694.</li> <li>\ub2e4\ub978 \ud504\ub85c\uadf8\ub7a8\uc774 \ucd5c\uc0c1\uc704 \ucc3d\uc73c\ub85c \uc124\uc815\ub418\uc5b4 \uc788\uc9c0 \uc54a\uc740\uc9c0 \ud655\uc778\ud558\uc138\uc694.</li> <li>\ud504\ub85c\uadf8\ub7a8\uc744 \uc7ac\uc2dc\uc791\ud574\ubcf4\uc138\uc694.</li> </ol> <ol> <li>\uc124\uc815 \ucc3d\uc758 \ud22c\uba85\ub3c4 \uc2ac\ub77c\uc774\ub354\uac00 \uc791\ub3d9\ud558\ub294\uc9c0 \ud655\uc778\ud558\uc138\uc694.</li> <li>\ud504\ub85c\uadf8\ub7a8\uc744 \uc7ac\uc2dc\uc791\ud574\ubcf4\uc138\uc694.</li> <li>\uadf8\ub798\ud53d \ub4dc\ub77c\uc774\ubc84\uac00 \ucd5c\uc2e0 \ubc84\uc804\uc778\uc9c0 \ud655\uc778\ud558\uc138\uc694.</li> </ol> <ol> <li>\ud504\ub9b0\ud130\uac00 \uc5f0\uacb0\ub418\uc5b4 \uc788\ub294\uc9c0 \ud655\uc778\ud558\uc138\uc694.</li> <li>\ud504\ub9b0\ud130 \ub4dc\ub77c\uc774\ubc84\uac00 \ucd5c\uc2e0 \ubc84\uc804\uc778\uc9c0 \ud655\uc778\ud558\uc138\uc694.</li> <li>\ub2e4\ub978 \ud504\ub85c\uadf8\ub7a8\uc5d0\uc11c \uc778\uc1c4\uac00 \ub418\ub294\uc9c0 \ud655\uc778\ud558\uc138\uc694.</li> </ol>"},{"location":"troubleshooting/#_4","title":"\uc5c5\ub370\uc774\ud2b8 \uad00\ub828 \ubb38\uc81c","text":"\uc5c5\ub370\uc774\ud2b8 \uc54c\ub9bc\uc774 \uacc4\uc18d \ud45c\uc2dc\ub418\ub294 \uacbd\uc6b0\uc5c5\ub370\uc774\ud2b8 \ud6c4 \ubb38\uc81c\uac00 \ubc1c\uc0dd\ud558\ub294 \uacbd\uc6b0 <ol> <li>\ucd5c\uc2e0 \ubc84\uc804\uc73c\ub85c \uc5c5\ub370\uc774\ud2b8\ud558\uc138\uc694.</li> <li>\uc124\uc815\uc5d0\uc11c \uc790\ub3d9 \uc5c5\ub370\uc774\ud2b8 \ud655\uc778\uc744 \ube44\ud65c\uc131\ud654\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> <li>GitHub \ub9b4\ub9ac\uc988 \ud398\uc774\uc9c0\uc5d0\uc11c \ucd5c\uc2e0 \ubc84\uc804\uc744 \ud655\uc778\ud558\uc138\uc694.</li> </ol> <ol> <li>\ud504\ub85c\uadf8\ub7a8\uc744 \uc7ac\uc2dc\uc791\ud574\ubcf4\uc138\uc694.</li> <li>\uc774\uc804 \ubc84\uc804\uc73c\ub85c \ub3cc\uc544\uac00\ubcf4\uc138\uc694.</li> <li>GitHub \uc774\uc288 \ud398\uc774\uc9c0\uc5d0 \ubb38\uc81c\ub97c \ubcf4\uace0\ud558\uc138\uc694. </li> </ol>"},{"location":"usage/","title":"\uc0ac\uc6a9 \uac00\uc774\ub4dc","text":""},{"location":"usage/#_2","title":"\uae30\ubcf8 \uc0ac\uc6a9\ubc95","text":""},{"location":"usage/#_3","title":"\ud560 \uc77c \ucd94\uac00\ud558\uae30","text":"<ol> <li>\uac01 \ubd84\uba74\uc758 \uc785\ub825\ucc3d\uc5d0 \ud560 \uc77c\uc744 \uc785\ub825\ud569\ub2c8\ub2e4.</li> <li>Enter \ud0a4\ub97c \ub204\ub974\uac70\ub098 \ucd94\uac00 \ubc84\ud2bc\uc744 \ud074\ub9ad\ud569\ub2c8\ub2e4.</li> <li>\uc911\uc694\ub3c4\uc640 \uae34\uae09\ub3c4\uc5d0 \ub530\ub77c \uc801\uc808\ud55c \ubd84\uba74\uc744 \uc120\ud0dd\ud569\ub2c8\ub2e4.</li> </ol>"},{"location":"usage/#_4","title":"\ud560 \uc77c \uad00\ub9ac\ud558\uae30","text":"<ul> <li>\uccb4\ud06c\ubc15\uc2a4\ub97c \ud074\ub9ad\ud558\uc5ec \uc644\ub8cc\ub41c \ud560 \uc77c\uc744 \ud45c\uc2dc\ud569\ub2c8\ub2e4.</li> <li>\ud56d\ubaa9\uc744 \ub354\ube14 \ud074\ub9ad\ud558\uc5ec \ub0b4\uc6a9\uc744 \uc218\uc815\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> <li>\ud56d\ubaa9\uc744 \uc6b0\ud074\ub9ad\ud558\uc5ec \uc0c1\uc138\ubcf4\uae30, \uc218\uc815, \uc0ad\uc81c \uba54\ub274\ub97c \uc0ac\uc6a9\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> </ul>"},{"location":"usage/#_5","title":"\uc124\uc815 \uc0ac\uc6a9\ud558\uae30","text":"<ul> <li>\u2699\ufe0f \ubc84\ud2bc\uc744 \ud074\ub9ad\ud558\uc5ec \uc124\uc815 \ucc3d\uc744 \uc5fd\ub2c8\ub2e4.</li> <li>\ud22c\uba85\ub3c4 \uc2ac\ub77c\uc774\ub354\ub85c \ucc3d\uc758 \ud22c\uba85\ub3c4\ub97c \uc870\uc808\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> <li>\ud83d\udccc \ubc84\ud2bc\uc73c\ub85c \ucc3d\uc744 \ud56d\uc0c1 \uc704\uc5d0 \uace0\uc815\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> </ul>"},{"location":"usage/#_6","title":"\uace0\uae09 \uae30\ub2a5","text":""},{"location":"usage/#_7","title":"\ub370\uc774\ud130 \uad00\ub9ac","text":"<ul> <li>\uc124\uc815 \ucc3d\uc5d0\uc11c \uc218\ub3d9\uc73c\ub85c \ub370\uc774\ud130\ub97c \uc800\uc7a5\ud558\uace0 \ubd88\ub7ec\uc62c \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> <li>\uc790\ub3d9 \uc800\uc7a5 \uae30\ub2a5\uc774 \uae30\ubcf8\uc801\uc73c\ub85c \ud65c\uc131\ud654\ub418\uc5b4 \uc788\uc2b5\ub2c8\ub2e4.</li> </ul>"},{"location":"usage/#_8","title":"\uc778\uc1c4 \uae30\ub2a5","text":"<ul> <li>\uc124\uc815 \ucc3d\uc5d0\uc11c \uc778\uc1c4 \ubc84\ud2bc\uc744 \ud074\ub9ad\ud558\uc5ec \uccb4\ud06c\ub9ac\uc2a4\ud2b8\ub97c \uc778\uc1c4\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> <li>\uc778\uc1c4 \uc2dc \uccb4\ud06c\ub41c \ud56d\ubaa9\uacfc \uba54\ubaa8\uac00 \ud3ec\ud568\ub429\ub2c8\ub2e4.</li> </ul>"},{"location":"usage/#_9","title":"\uc790\ub3d9 \uc5c5\ub370\uc774\ud2b8","text":"<ul> <li>\uc0c8\ub85c\uc6b4 \ubc84\uc804\uc774 \ucd9c\uc2dc\ub418\uba74 \uc790\ub3d9\uc73c\ub85c \uc54c\ub9bc\uc774 \ud45c\uc2dc\ub429\ub2c8\ub2e4.</li> <li>\uc5c5\ub370\uc774\ud2b8\ub97c \uc120\ud0dd\ud558\uba74 \ucd5c\uc2e0 \ubc84\uc804\uc744 \ub2e4\uc6b4\ub85c\ub4dc\ud558\uace0 \uc124\uce58\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. </li> </ul>"},{"location":"user-guide/","title":"\uc0ac\uc6a9 \ubc29\ubc95 \uac00\uc774\ub4dc","text":"<ul> <li> <p> \uae30\ubcf8 \uc0ac\uc6a9\ubc95</p> <ul> <li>\ud560 \uc77c \ucd94\uac00\ud558\uae30</li> <li>\ud560 \uc77c \uccb4\ud06c\ud558\uae30</li> <li>\uc0c1\uc138 \ub0b4\uc6a9 \ubcf4\uae30/\uc218\uc815</li> <li>\ud56d\ubaa9 \uad00\ub9ac\ud558\uae30</li> </ul> </li> <li> <p> \ud504\ub85c\uadf8\ub7a8 \uc124\uc815</p> <ul> <li>\uc790\ub3d9 \uc800\uc7a5 \uc124\uc815</li> <li>\ud654\uba74 \uc124\uc815</li> <li>\ub370\uc774\ud130 \uad00\ub9ac</li> </ul> </li> <li> <p> \ub9e4\ud2b8\ub9ad\uc2a4 \ud65c\uc6a9\ubc95</p> <ul> <li>1\uc0ac\ubd84\uba74: \uc911\uc694\ud558\uace0 \uae34\uae09\ud55c \uc77c</li> <li>2\uc0ac\ubd84\uba74: \uc911\uc694\ud558\uc9c0\ub9cc \uae34\uae09\ud558\uc9c0 \uc54a\uc740 \uc77c</li> <li>3\uc0ac\ubd84\uba74: \uae34\uae09\ud558\uc9c0\ub9cc \uc911\uc694\ud558\uc9c0 \uc54a\uc740 \uc77c</li> <li>4\uc0ac\ubd84\uba74: \uc911\uc694\ud558\uc9c0\ub3c4 \uae34\uae09\ud558\uc9c0\ub3c4 \uc54a\uc740 \uc77c</li> </ul> </li> </ul>"},{"location":"user-guide/#_2","title":"\uae30\ubcf8 \uc0ac\uc6a9\ubc95","text":"\ud560 \uc77c \ucd94\uac00\ud558\uae30\ud560 \uc77c \uccb4\ud06c\ud558\uae30\uc0c1\uc138 \ub0b4\uc6a9 \ubcf4\uae30/\uc218\uc815\ud56d\ubaa9 \uad00\ub9ac\ud558\uae30 <ol> <li>\uc6d0\ud558\ub294 \ubd84\uba74\uc744 \uc120\ud0dd\ud569\ub2c8\ub2e4</li> <li>\uc785\ub825\ucc3d\uc5d0 \ud560 \uc77c\uc744 \uc785\ub825\ud569\ub2c8\ub2e4</li> <li>Enter \ud0a4\ub97c \ub204\ub974\uac70\ub098 \ucd94\uac00 \ubc84\ud2bc\uc744 \ud074\ub9ad\ud569\ub2c8\ub2e4</li> </ol> <ul> <li>\ud56d\ubaa9\uc744 \ud074\ub9ad\ud558\uba74 \uccb4\ud06c/\uccb4\ud06c\ud574\uc81c\ub429\ub2c8\ub2e4</li> <li>\uccb4\ud06c\ub41c \ud56d\ubaa9\uc740 \ucde8\uc18c\uc120\uc774 \uadf8\uc5b4\uc9d1\ub2c8\ub2e4</li> </ul> <ul> <li>\ud56d\ubaa9\uc744 \ub354\ube14 \ud074\ub9ad\ud558\uac70\ub098</li> <li>\ud56d\ubaa9\uc744 \uc6b0\ud074\ub9ad\ud558\uc5ec '\uc0c1\uc138\ubcf4\uae30' \uc120\ud0dd</li> <li>\uc0c1\uc138 \ub0b4\uc6a9\uc744 \uc785\ub825\ud558\uace0 \uc800\uc7a5\ud569\ub2c8\ub2e4</li> </ul> <ul> <li>\uc218\uc815: \ud56d\ubaa9 \uc6b0\ud074\ub9ad \u2192 '\uc218\uc815' \uc120\ud0dd</li> <li>\uc0ad\uc81c: \ud56d\ubaa9 \uc6b0\ud074\ub9ad \u2192 '\uc0ad\uc81c' \uc120\ud0dd</li> </ul>"},{"location":"user-guide/#_3","title":"\ud504\ub85c\uadf8\ub7a8 \uc124\uc815","text":"\uc790\ub3d9 \uc800\uc7a5 \uc124\uc815\ud654\uba74 \uc124\uc815\ub370\uc774\ud130 \uad00\ub9ac <ol> <li>\uc124\uc815 \ubc84\ud2bc(\u2699\ufe0f) \ud074\ub9ad</li> <li>'\ub370\uc774\ud130 \uad00\ub9ac' \ud0ed \uc120\ud0dd</li> <li>'\uc790\ub3d9 \uc800\uc7a5 \uc0ac\uc6a9' \uccb4\ud06c\ubc15\uc2a4 \uc120\ud0dd/\ud574\uc81c</li> </ol> <ul> <li>\ud22c\uba85\ub3c4 \uc870\uc808: \uc6b0\uce21 \uc0c1\ub2e8\uc758 \uc2ac\ub77c\uc774\ub354\ub97c \uc6c0\uc9c1\uc5ec \ud22c\uba85\ub3c4 \uc870\uc815</li> <li>\ud56d\uc0c1 \uc704\uc5d0: \uc6b0\uce21 \uc0c1\ub2e8\uc758 \ud540 \ubc84\ud2bc(\ud83d\udccc)\uc744 \ud074\ub9ad\ud558\uc5ec \uc124\uc815/\ud574\uc81c</li> </ul> <ul> <li>\uc218\ub3d9 \uc800\uc7a5: \uc124\uc815 \u2192 '\uc800\uc7a5' \ubc84\ud2bc \ud074\ub9ad</li> <li>\ubd88\ub7ec\uc624\uae30: \uc124\uc815 \u2192 '\ubd88\ub7ec\uc624\uae30' \ubc84\ud2bc \ud074\ub9ad</li> <li>\ud504\ub9b0\ud2b8: \uc124\uc815 \u2192 '\ud504\ub9b0\ud2b8' \ubc84\ud2bc \ud074\ub9ad</li> </ul>"},{"location":"user-guide/#_4","title":"\uc544\uc774\uc820\ud558\uc6cc \ub9e4\ud2b8\ub9ad\uc2a4 \ud65c\uc6a9\ubc95","text":"1\uc0ac\ubd84\uba742\uc0ac\ubd84\uba743\uc0ac\ubd84\uba744\uc0ac\ubd84\uba74 <p>\uc911\uc694\ud558\uace0 \uae34\uae09\ud55c \uc77c</p> <ul> <li>\uc989\uc2dc \ucc98\ub9ac\ud574\uc57c \ud558\ub294 \uc911\uc694\ud55c \uc5c5\ubb34</li> <li>\uc608: \ub9c8\uac10\uc774 \uc784\ubc15\ud55c \ubcf4\uace0\uc11c, \uae34\uae09 \ubbf8\ud305</li> </ul> <p>\uc911\uc694\ud558\uc9c0\ub9cc \uae34\uae09\ud558\uc9c0 \uc54a\uc740 \uc77c</p> <ul> <li>\uacc4\ud68d\uc744 \uc138\uc6cc \ucc98\ub9ac\ud560 \uc911\uc694\ud55c \uc77c</li> <li>\uc608: \uc790\uae30\uacc4\ubc1c, \uc6b4\ub3d9, \uc7a5\uae30 \ud504\ub85c\uc81d\ud2b8</li> </ul> <p>\uae34\uae09\ud558\uc9c0\ub9cc \uc911\uc694\ud558\uc9c0 \uc54a\uc740 \uc77c</p> <ul> <li>\uac00\ub2a5\ud558\uba74 \uc704\uc784\ud558\uac70\ub098 \ucd5c\uc18c\ud654\ud560 \uc77c</li> <li>\uc608: \uac11\uc791\uc2a4\ub7ec\uc6b4 \uc694\uccad, \uc77c\uc0c1\uc801\uc778 \uc5c5\ubb34</li> </ul> <p>\uc911\uc694\ud558\uc9c0\ub3c4 \uae34\uae09\ud558\uc9c0\ub3c4 \uc54a\uc740 \uc77c</p> <ul> <li>\ucd5c\uc18c\ud654\ud558\uac70\ub098 \uc81c\uac70\ud560 \uc77c</li> <li>\uc608: \ubd88\ud544\uc694\ud55c \ud68c\uc758, SNS </li> </ul>"}]}